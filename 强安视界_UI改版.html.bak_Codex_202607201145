}

/* ---------- 智能排名 ---------- */
function rankNews(items) {
  // 归一化 hotValue（0-100 区间映射）
  var maxHot = 0;
  items.forEach(function(item) { if ((item.hotValue || 0) > maxHot) maxHot = item.hotValue || 0; });

  // 分类权重：国情/军事 > 科技 > 民生 > 财经生活
  var catWeight = { "国情": 1.2, "军事": 1.15, "科技": 1.1, "民生": 1.05, "财经生活": 1.0 };

  items.forEach(function(item) {
    var score = 0;

    // 1. 热度分（0-40 分）
    var hotNorm = maxHot > 0 ? ((item.hotValue || 0) / maxHot) : 0;
    score += hotNorm * 40;

    // 2. 标题吸引力分（0-35 分）
    var title = item.title || "";
    var attract = 0;
    // 含数字
    if (/\d/.test(title)) attract += 8;
    // 含疑问/悬念词
    if (/[？?]/.test(title) || /为何|为什么|原因|背后|真相|内幕|曝光|突发|刚刚|震惊|重磅|紧急/.test(title)) attract += 10;
    // 含冲突/对比词
    if (/但|竟|却|居然|意外|反转|逆袭|突破|首次|第一|新高|创/.test(title)) attract += 10;
    // 含动作词（让标题有张力）
    if (/宣布|警告|出手|启动|叫停|暴跌|暴涨|飙升|崩了|火了/.test(title)) attract += 7;
    // 长度适中（8-25字最佳）
    var len = title.length;
    if (len >= 8 && len <= 25) attract += 5;
    else if (len >= 5 && len <= 35) attract += 2;
    score += attract;

    // 3. 分类权重（0-15 分）
    var cw = catWeight[item.category] || 1.0;
    score += cw * 10;

    // 4. 时效性（0-10 分）- 当日热榜源头天然得分
    if (item.source === "今日头条" || item.source.indexOf("百度热榜") === 0) score += 10;
    else if (item.pubDate) score += 3;

    item._score = Math.round(score * 10) / 10;
  });

  // 按 _score 降序排列
  items.sort(function(a, b) { return (b._score || 0) - (a._score || 0); });

  // 重新分配 id
  items.forEach(function(item, i) { item.id = "n" + i; });

  return items;
}

