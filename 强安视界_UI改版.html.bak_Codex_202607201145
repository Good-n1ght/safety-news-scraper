  // 第二步：体育类条件屏蔽 —— 仅当标题不包含国情/军事/科技/民生语境时才屏蔽
  for (var i = 0; i < SPORTS_KEYWORDS.length; i++) {
    if (text.indexOf(SPORTS_KEYWORDS[i].toLowerCase()) !== -1) {
      // 纯体育娱乐 → 屏蔽；混合正经语境 → 放行
      return !hasSeriousContext(text);
