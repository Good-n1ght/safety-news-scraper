      .then(function(resp) {
        if (!resp.ok) throw new Error("HTTP " + resp.status);
        return resp.text();
      })
      .then(function(html) {
        var results = [];
        // 匹配 <li class="b_algo"> ... </li>
        var re = /<li class="b_algo"[^>]*>([\s\S]*?)<\/li>/gi;
        var mBlock;
        while ((mBlock = re.exec(html)) !== null && results.length < 5) {
          var block = mBlock[1];
          var titleM = block.match(/<h2[^>]*>\s*<a[^>]*href="(https?:\/\/[^"]*)"[^>]*>([\s\S]*?)<\/a>\s*<\/h2>/i);
          if (!titleM) continue;
          var link = titleM[1];
          var title = titleM[2].replace(/<[^>]+>/g, "").trim();
          if (!title || link.indexOf("http") !== 0) continue;
          // 摘要
          var snippetM = block.match(/<p[^>]*class="[^"]*\b(line-clamp|b_lineclamp)\b[^"]*"[^>]*>([\s\S]*?)<\/p>/i)
                      || block.match(/<div[^>]*class="[^"]*\bb_caption\b[^"]*"[^>]*>[\s\S]*?<p[^>]*>([\s\S]*?)<\/p>/i)
                      || block.match(/<p[^>]*>([\s\S]*?)<\/p>/i);
          var summary = snippetM ? snippetM[2] || snippetM[1] : "";
          summary = summary.replace(/<[^>]+>/g, "").trim();
          results.push({
            title: truncateTitle(title),
            link: link,
            summary: summary,
            full_text: "",
            has_full: false,
            pubDate: "",
            source: src.name
          });
        }
        return results;
      })
      .catch(function(err) {
        console.warn("搜索聚合失败: " + src.name, err.message);
        return [];
      });
  }

  return Promise.all(SEARCH_SOURCES.map(fetchOne))
    .then(function(results) {
      var all = [];
      results.forEach(function(arr) { all = all.concat(arr); });
      return all;
    });
}

/* ---------- 获取新闻 ---------- */
function fetchNews() {
  els.fetchBtn.disabled = true;
  els.rewriteBtn.disabled = true;
  newsItems = [];
  selectedIds = {};
  // 每次抓取新数据时清除旧改写缓存，确保显示原标题
  rewrittenCache = {};
  saveRewrittenCache();
  els.articleSection.hidden = true;
  els.copyBar.hidden = true;
  setAiProcess(false);
  generatedArticles = [];

  setStatus("loading", "正在从 RSS 实时获取...");
  els.countText.textContent = "";
  els.newsList.innerHTML = '<div class="loading-row">正在从多个新闻源拉取...</div>';

  var promises = RSS_SOURCES.map(function(src) {
    var fetchUrl = RSS2JSON_API + encodeURIComponent(src.url) + "&_t=" + Date.now();
    return fetch(fetchUrl)
      .then(function(resp) {
        if (!resp.ok) throw new Error("HTTP " + resp.status);
        return resp.json();
      })
      .then(function(data) {
        if (data.status !== "ok") throw new Error("rss2json API error");
        return (data.items || []).map(function(item) {
          return {
            title: truncateTitle((item.title || "").replace(/<[^>]+>/g, "").trim()),
            link: item.link || "",
            summary: (item.description || "").replace(/<\/p>\s*<p>/gi, "\n\n").replace(/<br\s*\/?>/gi, "\n").replace(/<[^>]+>/g, "").replace(/&amp;/g, "&").replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/&quot;/g, '"').replace(/&#39;/g, "'").trim(),
            full_text: "",
            has_full: false,
            pubDate: item.pubDate || "",
            source: src.name
          };
        });
      })
      .catch(function(err) {
        console.warn("RSS 获取失败: " + src.name, err.message);
        return [];
      });
  });

  // 追加今日头条热榜
  promises.push(fetchToutiaoNews());
  // 追加百度实时热榜（corsproxy.io，手机端可用）
  promises.push(fetchBaiduHot());
  // 追加搜索引擎聚合扩展源
  promises.push(fetchSearchSources());

  return Promise.all(promises).then(function(results) {
    var allItems = [];
    results.forEach(function(arr) { allItems = allItems.concat(arr); });

    // 去重（按标题）
    var seen = {};
    var uniqueItems = [];
    allItems.forEach(function(item) {
      var key = item.title.substring(0, 30);
      if (!seen[key]) {
        seen[key] = true;
        uniqueItems.push(item);
      }
    });

    // 过滤 + 分类
    var classified = uniqueItems
      .filter(function(item) { return !isBlocked(item.title, item.summary); })
      .map(function(item, index) {
        item.category = item.category || classifyNews(item.title, item.summary);
        item.id = "n" + index;
        item._originalTitle = item.title;
        return item;
      });

    // 控制热榜占比：头条源最多保留 TOUTIAO_MAX_KEEP 条，百度热榜最多保留 BAIDU_MAX_KEEP 条
    var toutiaoItems = [];
    var baiduItems = [];
    var rssItems = [];
    classified.forEach(function(item) {
      if (item.source === "今日头条") {
        toutiaoItems.push(item);
      } else if (item.source.indexOf("百度热榜") === 0) {
        baiduItems.push(item);
      } else {
        rssItems.push(item);
      }
    });
    // 头条按 hotValue 降序取前 N 条
    toutiaoItems.sort(function(a, b) { return (b.hotValue || 0) - (a.hotValue || 0); });
    toutiaoItems = toutiaoItems.slice(0, TOUTIAO_MAX_KEEP);
    // 百度热榜按 hotValue 降序取前 N 条
    baiduItems.sort(function(a, b) { return (b.hotValue || 0) - (a.hotValue || 0); });
    baiduItems = baiduItems.slice(0, BAIDU_MAX_KEEP);

    // 合并后重新排名（rankNews 内统一做截断兜底）
    var allMerged = rssItems.concat(toutiaoItems).concat(baiduItems);
    allMerged.forEach(function(item) { item.title = truncateTitle(item.title); });
    newsItems = rankNews(allMerged);
    // 全局按日期降序（最新在前），同日期内按评分排序
    newsItems.sort(function(a, b) {
      var da = a.pubDate || "", db = b.pubDate || "";
      if (da > db) return -1;
      if (da < db) return 1;
      return (b._score || 0) - (a._score || 0);
    });

    renderNews();
    els.fetchBtn.disabled = false;
    if (newsItems.length > 0) {
      els.rewriteBtn.disabled = false;
      setStatus("success", "已获取 " + newsItems.length + " 条新闻，可选分类过滤后点击「批量标题优化」");
    } else {
      setStatus("error", "未获取到新闻，请检查 CORS 代理是否可用");
    }
    els.countText.textContent = "共 " + newsItems.length + " 条";
  }).catch(function(err) {
    els.fetchBtn.disabled = false;
    setStatus("error", "获取失败: " + (err.message || "未知错误"));
    els.newsList.innerHTML = '<div class="empty-state"><div class="empty-icon">&#9888;</div><p>获取新闻失败，请检查 CORS 代理地址或网络连接</p></div>';
  });
}

/* ---------- 渲染新闻列表 ---------- */
function renderNews() {
  var filtered = newsItems;
  if (activeCategory !== "全部") {
    filtered = newsItems.filter(function(item) { return item.category === activeCategory; });
  }

  if (!filtered.length) {
    els.newsList.innerHTML = '<div class="empty-state"><p>当前分类下无新闻</p></div>';
  } else {
    els.newsList.innerHTML = filtered.map(function(item) {
      var selClass = selectedIds[item.id] ? " selected" : "";
      var checked  = selectedIds[item.id] ? " checked" : "";
      var displayTitle = rewrittenCache[item.id] || item.title;
      var aiBadge = rewrittenCache[item.id] ? ' <span class="badge-ai">AI</span>' : "";
      var hotBadge = "";
      return '<div class="news-item' + selClass + '" data-id="' + item.id + '">' +
        '<input type="checkbox" class="news-checkbox" data-id="' + item.id + '" ' + checked + ' />' +
        '<div class="news-body">' +
          '<div class="news-title">' + escapeHtml(displayTitle) + aiBadge + hotBadge + '</div>' +
          '<div class="news-meta">' +
            '<span>' + escapeHtml(item.source) + '</span>' +
            '<span>' + escapeHtml(item.pubDate || "") + '</span>' +
            '<span class="news-category">' + escapeHtml(item.category) + '</span>' +
          '</div>' +
          '<div class="news-actions">' +
            '<button class="btn-rewrite-item" data-id="' + item.id + '"' + (rewrittenCache[item.id] ? ' style="display:none"' : '') + '>标题优化</button>' +
            '<button class="btn-undo-item" data-id="' + item.id + '"' + (!rewrittenCache[item.id] ? ' style="display:none"' : '') + '>恢复原版标题</button>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join("");
  }

  updateGenerateBtn();
}

function updateGenerateBtn() {
  var count = Object.keys(selectedIds).length;
  els.selectedCount.textContent = count;
  els.generateBtn.disabled = count === 0;
}

/* ---------- AI 标题改写 ---------- */
function rewriteTitles() {
  if (!getApiKey()) {
    showToast("请先在设置面板中填写 API Key");
    els.settingsBtn.click();
    return;
  }
  var toRewrite = newsItems.filter(function(item) { return !rewrittenCache[item.id]; });
  if (toRewrite.length === 0) {
    showToast("所有标题已完成优化");
    return;
  }

  els.rewriteBtn.disabled = true;
  setStatus("loading", "AI 标题优化中...");

  // 每次处理 10 条
  var batchSize = 10;
  var batchIndex = 0;
  var totalBatches = Math.ceil(toRewrite.length / batchSize);

  function processBatch() {
    if (batchIndex >= toRewrite.length) {
      els.rewriteBtn.disabled = false;
      saveRewrittenCache();
      renderNews();
      setStatus("success", "标题优化完成，请勾选感兴趣的新闻后生成文章");
      showToast("标题优化完成");
      return;
    }

    var batch = toRewrite.slice(batchIndex, batchIndex + batchSize);
    var batchNum = Math.floor(batchIndex / batchSize) + 1;
    setStatus("loading", "AI 标题优化中 (" + batchNum + "/" + totalBatches + ")...");

    callAIRewrite(batch).then(function(rewritten) {
      rewritten.forEach(function(item) {
        if (item.title) rewrittenCache[item.id] = item.title;
      });
      batchIndex += batchSize;
      processBatch();
    }).catch(function(err) {
      console.warn("AI 改写失败:", err);
      // 失败回退：直接用原标题
      batch.forEach(function(item) {
        if (!rewrittenCache[item.id]) rewrittenCache[item.id] = item.title;
      });
      batchIndex += batchSize;
      processBatch();
    });
  }

  processBatch();
}

function callAIRewrite(batchItems) {
  var titles = batchItems.map(function(item, i) {
    return (i + 1) + ". " + item.title + "（来源：" + item.source + "）";
  }).join("\n");

  var systemPrompt = els.groundMode && els.groundMode.checked
    ? "你是一个服务煤矿工人群体的新闻编辑。请将以下新闻标题改写得更吸引眼球，参考今日头条风格——用冲突、悬念、数字、反差、通俗比喻来抓注意力，但不变更事实、不低俗不煽动。读者是煤矿一线职工，语言要做到通俗化表达、有温度、能让他们产生兴趣点开阅读。对每条输入，输出对应序号的改写标题，严格按照 JSON 数组格式：\n[{\"id\":\"序号\",\"title\":\"改写后标题\"}]"
    : "你是一个新闻标题优化专家。请将以下新闻标题进行优化改写——保留事实和来源、不改变原意，让标题更适合职工阅读。不要改变事实，不要添加原文没有的信息，只是让表达更清晰易懂。对每条输入，输出对应序号的改写标题，严格按照 JSON 数组格式：\n[{\"id\":\"序号\",\"title\":\"改写后标题\"}]";

  var userPrompt = "请改写以下新闻标题：\n" + titles + "\n\n请直接输出 JSON 数组，不要输出任何其他内容。";

  return callDeepSeekDraft({systemPrompt: systemPrompt, userPrompt: userPrompt}).then(function(raw) {
    try {
      var parsed = JSON.parse(raw);
      var result = [];
      parsed.forEach(function(r) {
        var idx = parseInt(r.id, 10) - 1;
        if (idx >= 0 && idx < batchItems.length) {
          result.push({ id: batchItems[idx].id, title: r.title });
        }
      });
      return result;
    } catch(e) {
      // 解析失败，回退
      return batchItems.map(function(item) { return { id: item.id, title: item.title }; });
    }
  });
}

/* ---------- 单条标题优化 ---------- */
function rewriteSingleTitle(itemId) {
  if (!getApiKey()) {
    showToast("请先在设置面板中填写 API Key");
    els.settingsBtn.click();
    return;
  }
  var item = null;
  for (var i = 0; i < newsItems.length; i++) {
    if (newsItems[i].id === itemId) { item = newsItems[i]; break; }
  }
  if (!item) return;

  // 保存原始标题
  if (!item._originalTitle) item._originalTitle = item.title;

  setStatus("loading", "AI 标题优化中...");

  callAIRewrite([item]).then(function(rewritten) {
    if (rewritten[0] && rewritten[0].title) {
      rewrittenCache[itemId] = rewritten[0].title;
    }
    saveRewrittenCache();
    renderNews();
    setStatus("success", "标题优化完成");
  }).catch(function() {
    renderNews();
    setStatus("error", "标题优化失败，请重试");
  });
}

/* ---------- 撤销单条标题优化 ---------- */
function undoRewrite(itemId) {
  delete rewrittenCache[itemId];
  saveRewrittenCache();
  renderNews();
  setStatus("success", "已恢复原版标题");
}

