/* ---------- AI 写稿 ---------- */
function generateArticles() {
  var selectedItems = newsItems.filter(function(item) { return selectedIds[item.id]; });
  if (!selectedItems.length) {
    showToast("请先勾选新闻");
    return;
  }

  els.generateBtn.disabled = true;
  setAiProcess(true, "正在读取已选资讯并组织稿件");
  var total = selectedItems.length;
  var done = 0;
  generatedArticles = [];
  els.articleSection.hidden = false;
  els.copyBar.hidden = false;
  els.articleSection.innerHTML = '<div class="loading-row">AI 正在写文章 (0/' + total + ')...</div>';

  var SYSTEM = "你是一位资深新闻编辑，面向35-55岁成年男性读者写新闻稿。要求：\n" +
    "1. 根据新闻标题写一篇500-800字的新闻解读，结构：标题 → 导语（核心冲突/亮点，2-3句） → 正文 → 收尾\n" +
    "2. 标题要吸引点击，但不能低俗煽动——用冲突、悬念、数字、反差来抓眼球\n" +
    "3. 导语直接抛出最核心的信息，不铺垫不啰嗦\n" +
    "4. 正文要有干货（数据、事实、前因后果），语言干净利落，不喊口号不装腔\n" +
    "5. 文末一行：参考来源：[来源名称]，原文链接：[链接]\n" +
    "6. 输出纯JSON：{\"title\":\"标题\",\"article\":\"正文\"}";

  function processOne(index) {
    if (index >= total) {
      els.generateBtn.disabled = false;
      renderGeneratedArticles();
      setStatus("success", "AI 写稿完成，共 " + generatedArticles.length + " 篇");
      setAiProcess(false);
      return;
    }

    var item = selectedItems[index];
    var itemTitle = rewrittenCache[item.id] || item.title;
    setStatus("loading", "AI 写稿 (" + (index + 1) + "/" + total + "): " + itemTitle.substring(0, 18) + "...");
    setAiProcess(true, "正在处理第 " + (index + 1) + " 条线索：" + itemTitle.substring(0, 16));

    var userPrompt = "新闻标题：" + itemTitle +
      "\n来源：" + item.source +
      "\n原文链接：" + (item.link || "无") +
      "\n\n【以下为原文素材，请基于此写稿】\n" + (item.full_text || item.summary || "无素材") +
      "\n\n请直接输出JSON。";

    callDeepSeekDraft({systemPrompt: SYSTEM, userPrompt: userPrompt}).then(function(raw) {
      var article;
      try {
        article = JSON.parse(raw.match(/\{[\s\S]*\}/)[0]);
      } catch(e) {
        article = { title: itemTitle, article: item.summary || "AI 写稿失败，请查看原文：" + (item.link || "") };
      }
      generatedArticles.push({
        title: article.title || itemTitle,
        article: article.article || "",
        source: item.source,
        link: item.link
      });
      done++;
      els.articleSection.innerHTML = '<div class="loading-row">AI 正在写文章 (' + done + '/' + total + ')...</div>';
      processOne(index + 1);
    }).catch(function(err) {
      console.warn("AI 写稿失败:", err);
      generatedArticles.push({
        title: itemTitle,
        article: "AI 写稿失败，请查看原文：" + (item.link || ""),
        source: item.source,
        link: item.link
      });
      done++;
      els.articleSection.innerHTML = '<div class="loading-row">AI 正在写文章 (' + done + '/' + total + ')...</div>';
      processOne(index + 1);
    });
  }

  processOne(0);
}

function renderGeneratedArticles() {
  els.articleSection.innerHTML = generatedArticles.map(function(article, i) {
    var title = escapeHtml(article.title);
    var body = article.article
      ? article.article.replace(/\n/g, '<br>')
      : "点击阅读原文查看详情";
    var sourceHtml = "来源：" + escapeHtml(article.source) +
      (article.link ? ' · <a href="' + escapeHtml(article.link) + '" target="_blank" rel="noopener">阅读原文</a>' : "");

    // 装饰性头图：按序号换色
    var colors = ["#1a5276","#117a65","#935116","#76448a","#b03a2e","#1e8449"];
    var barColor = colors[i % colors.length];

    return '<div class="article-card">' +
      '<div class="article-card-bar" style="background:' + barColor + ';"></div>' +
      '<div class="article-card-body">' +
        '<h3>' + title + '</h3>' +
        '<div class="article-summary">' + body + '</div>' +
        '<div class="source-link">' + sourceHtml + '</div>' +
      '</div>' +
    '</div>';
  }).join("");

  els.articleSection.scrollIntoView({ behavior: "smooth", block: "start" });
}

/* ---------- 复制全部 ---------- */
function copyAll() {
  if (!generatedArticles.length) return;
  var text = generatedArticles.map(function(a) {
    return "【" + a.title + "】\n" + (a.article || "") + "\n来源：" + a.source + (a.link ? " " + a.link : "");
  }).join("\n\n---\n\n");

  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(function() {
      showToast("已复制全部");
    }).catch(function() {
      showToast("复制失败，请手动复制");
    });
  } else {
    showToast("当前浏览器不支持自动复制");
  }
}

/* ---------- 选择逻辑 ---------- */
function toggleSelect(id) {
  if (selectedIds[id]) {
    delete selectedIds[id];
  } else {
    selectedIds[id] = true;
  }
  renderNews();
}

function selectAll() {
  var filtered = newsItems;
  if (activeCategory !== "全部") {
    filtered = newsItems.filter(function(item) { return item.category === activeCategory; });
  }
  filtered.forEach(function(item) { selectedIds[item.id] = true; });
  renderNews();
}

function deselectAll() {
  selectedIds = {};
  renderNews();
}

/* ---------- 事件绑定 ---------- */
function bindEvents() {
  console.log("=== BIND EVENTS ===");
  // 新闻列表点击
  console.log("bound: newsList");
  els.newsList.addEventListener("click", function(e) {
    var cb = e.target.closest(".news-checkbox");
    if (cb) {
      e.stopPropagation();
      toggleSelect(cb.dataset.id);
      return;
    }
    var item = e.target.closest(".news-item");
    if (item) {
      var cb2 = item.querySelector(".news-checkbox");
      if (cb2) toggleSelect(cb2.dataset.id);
    }
  });

  console.log("bound: selectAllBtn");
  els.selectAllBtn.addEventListener("click", selectAll);
  console.log("bound: deselectAllBtn");
  els.deselectAllBtn.addEventListener("click", deselectAll);
  console.log("bound: fetchBtn");
  els.fetchBtn.addEventListener("click", fetchNews);
  console.log("bound: rewriteBtn");
  els.rewriteBtn.addEventListener("click", rewriteTitles);
  // 事件委托：单条标题优化 / 撤销按钮（动态渲染）
  els.newsList.addEventListener("click", function(e) {
    var btn = e.target.closest(".btn-rewrite-item");
    if (btn) { e.preventDefault(); rewriteSingleTitle(btn.dataset.id); return; }
    btn = e.target.closest(".btn-undo-item");
    if (btn) { e.preventDefault(); undoRewrite(btn.dataset.id); return; }
  });
  console.log("bound: generateBtn");
  els.generateBtn.addEventListener("click", generateArticles);
  console.log("bound: copyAllBtn");
  els.copyAllBtn.addEventListener("click", copyAll);

  console.log("bound: categoryFilter");
  els.categoryFilter.addEventListener("change", function() {
    activeCategory = els.categoryFilter.value;
    renderNews();
  });
}

