/* ---------- RSS 解析 ---------- */
function parseRSS(xmlText) {
  var items = [];
  var reItem = /<item>([\s\S]*?)<\/item>/gi;
  var match;
  while ((match = reItem.exec(xmlText)) !== null) {
    var block = match[1];
    var title   = (block.match(/<title>(.*?)<\/title>/i)   || [])[1] || "";
    var link    = (block.match(/<link>(.*?)<\/link>/i)     || [])[1] || "";
    var desc    = (block.match(/<description>(.*?)<\/description>/i) || [])[1] || "";
    var pubDate = (block.match(/<pubDate>(.*?)<\/pubDate>/i) || [])[1] || "";
    // clean HTML tags from title & description
    title = title.replace(/<[^>]+>/g, "").trim();
    desc  = desc.replace(/<[^>]+>/g, "").trim();
    if (title) {
      items.push({ title: title, link: link, summary: desc, pubDate: pubDate });
    }
  }
  return items;
}

/* ---------- 今日头条多分类 feed 抓取 ---------- */
function fetchToutiaoNews() {
  var controller = new AbortController();
  var timeoutId = setTimeout(function() { controller.abort(); }, TOUTIAO_TIMEOUT_MS);

  function fetchOne(url) {
    return fetch(CORS_PROXY + encodeURIComponent(url + "&_t=" + Date.now()), {
      signal: controller.signal,
      headers: { "Accept": "application/json" }
    })
      .then(function(resp) {
        if (!resp.ok) throw new Error("HTTP " + resp.status);
        return resp.json();
      })
      .then(function(data) {
        var articles = data.data || [];
        return articles
          .filter(function(a) { return a.article_genre === "article"; })
          .map(function(a) {
            var link = a.source_url || "";
            if (link && link.indexOf("http") !== 0) link = "https://www.toutiao.com" + link;
            // 热度近似值：评论数 + 播放量/1000，保底 10
            var hot = (a.comments_count || 0) + Math.round((a.video_play_count || 0) / 1000);
            var rawTitle = (a.title || "").replace(/\s+/g, " ").trim();
            // 截断过长标题：30字符（约15个中文），超出加"..."
            var title = rawTitle.length > 30 ? rawTitle.slice(0, 30) + "..." : rawTitle;
            return {
              title: title,
              link: link,
              summary: (a.abstract || "").trim(),
              full_text: "",
              has_full: false,
              pubDate: "",
              source: "今日头条",
              hotValue: hot || 10
            };
          });
      })
      .catch(function(err) {
        console.warn("头条分类抓取失败: " + err.message);
        return [];
      });
  }

  return Promise.all(TOUTIAO_FEED_URLS.map(fetchOne))
    .then(function(results) {
      clearTimeout(timeoutId);
      // 合并所有分类，按标题去重，截断到 TOUTIAO_MAX_RAW
      var seen = {};
      var merged = [];
      results.forEach(function(arr) {
        arr.forEach(function(item) {
          if (!seen[item.title]) {
            seen[item.title] = true;
            merged.push(item);
          }
        });
      });
      return merged.slice(0, TOUTIAO_MAX_RAW);
    });
}

