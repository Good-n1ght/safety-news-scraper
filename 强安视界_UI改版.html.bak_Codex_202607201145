<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>强安视界 - 新闻聚合</title>
<style>
:root {
  color-scheme: light;
  --bg: #f5f7fa;
  --surface: #ffffff;
  --surface-strong: #f0f4f8;
  --text: #1a1a2e;
  --muted: #6b7280;
  --line: #e0e4e8;
  --primary: #1976D2;
  --primary-soft: #E3F2FD;
  --primary-dark: #1565C0;
  --red: #d32f2f;
  --red-soft: #ffebee;
  --green: #2e7d32;
  --green-soft: #e8f5e9;
  --amber: #e65100;
  --amber-soft: #fff3e0;
  --shadow: 0 2px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: "Microsoft YaHei", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  min-height: 100vh;
}

button, input, select, textarea { font: inherit; }
button { cursor: pointer; }
button:disabled { cursor: wait; opacity: 0.7; }

.app-shell {
  width: min(900px, 100%);
  margin: 0 auto;
  padding: 16px 14px 36px;
}

/* ===== Header ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 8px 0 16px;
  border-bottom: 2px solid var(--primary-soft);
  margin-bottom: 18px;
}
.header-left h1 {
  font-size: clamp(22px, 5vw, 30px);
  color: var(--primary);
  letter-spacing: 1px;
}
.header-left .date-text {
  font-size: 13px;
  color: var(--muted);
  margin-top: 2px;
}
.header-actions { display: flex; gap: 8px; }
.icon-btn {
  width: 40px; height: 40px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
  color: var(--text);
  font-size: 18px;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s;
}
.icon-btn:hover { background: var(--primary-soft); color: var(--primary); }

/* ===== Controls Bar ===== */
.controls-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 14px;
}
.controls-bar select {
  height: 38px;
  padding: 0 10px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
  color: var(--text);
  font-size: 14px;
  outline: none;
}
.controls-bar select:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(25,118,210,0.12);
}
.btn {
  height: 38px;
  padding: 0 16px;
  border: 0;
  border-radius: 8px;
  font-weight: 700;
  font-size: 14px;
  white-space: nowrap;
  transition: background 0.15s, transform 0.1s;
}
.btn:active { transform: scale(0.97); }
.btn-primary { background: var(--primary); color: #fff; }
.btn-primary:hover { background: var(--primary-dark); }
.btn-outline {
  background: var(--surface);
  color: var(--primary);
  border: 1px solid var(--primary);
}
.btn-outline:hover { background: var(--primary-soft); }
.btn-amber { background: var(--amber); color: #fff; }
.btn-amber:hover { background: #bf360c; }
.btn-green { background: var(--green); color: #fff; }
.btn-green:hover { background: #1b5e20; }
.btn-sm { height: 32px; padding: 0 12px; font-size: 13px; }

.spacer { flex: 1; }

/* ===== Status ===== */
.status-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
  font-size: 13px;
  color: var(--muted);
}
.status-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #ccc;
  flex-shrink: 0;
}
.status-dot.loading { background: var(--amber); animation: pulse 1s infinite; }
.status-dot.success { background: var(--green); }
.status-dot.error { background: var(--red); }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

/* ===== News List ===== */
.news-list { display: grid; gap: 8px; }

.news-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--surface);
  transition: border-color 0.15s, box-shadow 0.15s;
  cursor: pointer;
}
.news-item:hover {
  border-color: var(--primary);
  box-shadow: 0 2px 8px rgba(25,118,210,0.1);
}
.news-item.selected {
  border-color: var(--primary);
  background: var(--primary-soft);
}

.news-checkbox {
  width: 22px; height: 22px;
  margin-top: 2px;
  accent-color: var(--primary);
  cursor: pointer;
  flex-shrink: 0;
}
.news-body { flex: 1; min-width: 0; }
.news-title {
  font-size: 15px;
  font-weight: 800;
  line-height: 1.4;
  margin-bottom: 6px;
  color: var(--text);
}
.news-title .rewritten { color: var(--primary); }
.news-title .badge-ai {
  display: inline-block;
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 999px;
  background: var(--primary-soft);
  color: var(--primary);
  font-weight: 700;
  vertical-align: middle;
  margin-left: 4px;
}

.mode-toggle {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  color: var(--muted);
  cursor: pointer;
  user-select: none;
  margin-right: 4px;
}
.btn-rewrite-item {
  display: inline-block;
  font-size: 11px;
  padding: 2px 10px;
  border-radius: 4px;
  border: 1px solid #e65100;
  background: #fff;
  color: #e65100;
  cursor: pointer;
  font-weight: 600;
  margin-left: 8px;
  vertical-align: middle;
  transition: all 0.15s;
}
.btn-rewrite-item:hover { background: #fff3e0; }
.btn-undo-item {
  display: inline-block;
  font-size: 11px;
  padding: 2px 10px;
  border-radius: 4px;
  border: 1px solid #999;
  background: #fff;
  color: #666;
  cursor: pointer;
  font-weight: 600;
  margin-left: 4px;
  vertical-align: middle;
  transition: all 0.15s;
}
.btn-undo-item:hover { background: #f5f5f5; }
.news-meta {
  font-size: 12px;
  color: var(--muted);
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.news-category {
  display: inline-block;
  padding: 1px 8px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  background: #f0f4f8;
  color: #4a5568;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 48px 20px;
  color: var(--muted);
}
.empty-state .empty-icon { font-size: 48px; margin-bottom: 12px; }
.empty-state p { font-size: 14px; }

/* ===== Article Cards (generated) ===== */
.article-section {
  margin-top: 18px;
}
.article-card {
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--surface);
  margin-bottom: 14px;
  overflow: hidden;
  box-shadow: var(--shadow);
}
.article-card-img {
  width: 100%;
  max-height: 320px;
  object-fit: cover;
  display: block;
}
.article-card-img-placeholder {
  width: 100%;
  min-height: 140px;
  background: linear-gradient(135deg, var(--primary-soft), #BBDEFB);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-size: 14px;
  font-weight: 700;
}
.article-card-bar {
  height: 6px;
  width: 100%;
}
.article-card-body { padding: 16px; }
.article-card-body h3 {
  font-size: 17px;
  margin-bottom: 8px;
  color: var(--primary);
}
.article-card-body p {
  font-size: 14px;
  line-height: 1.7;
  color: #333;
  margin-bottom: 6px;
}
.article-card-body .article-summary {
  font-size: 14px;
  line-height: 1.8;
  color: #333;
  margin-bottom: 8px;
  white-space: pre-line;
}
.article-card-body .source-link {
  font-size: 12px;
  color: var(--muted);
  margin-top: 8px;
}
.article-card-body .source-link a {
  color: var(--primary);
  text-decoration: none;
}

/* ===== Settings Overlay ===== */
/* ===== Settings Overlay (共享) ===== */
.settings-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
}
.settings-overlay[hidden] { display: none; }

.settings-dialog {
  width: min(92vw, 460px);
  max-height: 85vh;
  overflow-y: auto;
  padding: 24px;
  border-radius: 12px;
  background: var(--surface);
  box-shadow: var(--shadow);
}
.settings-dialog h3 {
  margin: 0 0 18px;
  font-size: 18px;
}

.setting-row {
  margin-bottom: 14px;
}
.setting-label {
  display: block;
  margin-bottom: 6px;
  font-size: 13px;
  font-weight: 700;
  color: var(--muted);
}
.setting-row input,
.setting-row select {
  width: 100%;
  height: 40px;
  padding: 0 10px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #fff;
  color: var(--text);
  font-size: 14px;
  outline: none;
}
.setting-row input:focus,
.setting-row select:focus {
  border-color: #1976D2;
  box-shadow: 0 0 0 3px rgba(25, 118, 210, 0.12);
}
.setting-row .hint {
  margin-top: 4px;
  font-size: 12px;
  color: var(--muted);
}

.settings-actions {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
  margin-top: 20px;
}
.btn-cancel,
.btn-save {
  min-height: 38px;
  padding: 0 20px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  border: 0;
}
.btn-cancel {
  background: var(--surface-strong);
  color: var(--text);
  border: 1px solid var(--line);
}
.btn-cancel:hover { opacity: 0.8; }
.btn-save {
  background: #1976D2;
  color: #fff;
}
.btn-save:hover { background: #1565C0; }

/* ===== Toast (共享) ===== */
.toast {
  position: fixed;
  left: 50%;
  bottom: 20px;
  transform: translateX(-50%) translateY(20px);
  z-index: 2000;
  max-width: min(92vw, 420px);
  padding: 10px 16px;
  border-radius: 8px;
  background: rgba(26, 26, 46, 0.92);
  color: #fff;
  font-size: 14px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 160ms ease, transform 160ms ease;
}
.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}


/* ===== Toast ===== */
.toast {
  position: fixed;
  left: 50%;
  bottom: 20px;
  transform: translateX(-50%) translateY(20px);
  z-index: 2000;
  max-width: min(92vw, 400px);
  padding: 10px 16px;
  border-radius: 8px;
  background: rgba(26,26,46,0.92);
  color: #fff;
  font-size: 14px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 160ms ease, transform 160ms ease;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* ===== Loading ===== */
.loading-row {
  text-align: center;
  padding: 24px;
  color: var(--muted);
  font-size: 14px;
}

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .app-shell { padding: 12px 10px 28px; }
  .header { flex-wrap: wrap; gap: 8px; }
  .header-left h1 { font-size: 22px; }

  .controls-bar {
    gap: 8px;
    flex-direction: column;
    align-items: stretch;
  }

  .controls-bar select {
    width: 100%;
    font-size: 14px;
    height: 40px;
  }

  .controls-bar .spacer {
    display: none;
  }

  .controls-bar .btn {
    width: 100%;
    justify-content: center;
    text-align: center;
  }

  .controls-bar .mode-toggle {
    width: 100%;
    justify-content: center;
    padding: 8px;
  }

  .btn { height: 38px; padding: 0 14px; font-size: 14px; }
  .news-item { padding: 12px; }
  .news-title { font-size: 14px; }
  .news-grid { grid-template-columns: 1fr; }

  .status-row {
    flex-wrap: wrap;
    gap: 8px;
  }
}

@media (max-width: 480px) {
  .app-shell { padding: 8px 6px 20px; }
  .header { padding: 10px 8px 12px 12px; }
  .header-left h1 { font-size: 18px; }

  .controls-bar select { font-size: 13px; height: 36px; }
  .btn { height: 36px; font-size: 12px; padding: 0 10px; }
  .news-title { font-size: 13px; }
  .news-item { padding: 10px; }
  .date-text { font-size: 11px; }
}

/* ===== 演示版 UI 皮肤：强安视界 ===== */
:root {
  --bg: #f3f5f2;
  --surface: #ffffff;
  --surface-strong: #f7f8f4;
  --text: #17201d;
  --muted: #65716c;
  --line: #dfe5df;
  --primary: #11634f;
  --primary-soft: #e9f5ef;
  --primary-dark: #0d4f40;
  --red: #b42318;
  --red-soft: #fff1ed;
  --green: #16705a;
  --green-soft: #e8f5ef;
  --amber: #9a6500;
  --amber-soft: #fff7e6;
  --shadow: 0 10px 28px rgba(23, 32, 29, 0.07);
  --shadow-lg: 0 16px 36px rgba(23, 32, 29, 0.12);
}

body {
  background:
    linear-gradient(180deg, #faf8f4 0, #f3f5f2 260px, #f3f5f2 100%);
}

.app-shell {
  max-width: 980px;
  padding-top: 14px;
}

.header {
  position: relative;
  min-height: 94px;
  padding: 18px 18px 20px 22px;
  margin-bottom: 12px;
  border: 1px solid var(--line);
  border-bottom: 0;
  border-radius: 8px;
  background:
    linear-gradient(90deg, rgba(180, 35, 24, 0.07), rgba(17, 99, 79, 0.08)),
    var(--surface);
  box-shadow: var(--shadow);
}

.header::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 6px;
  height: 100%;
  border-radius: 8px 0 0 8px;
  background: linear-gradient(180deg, var(--red), var(--primary));
}

.header-left h1 {
  color: var(--text);
  font-size: 28px;
  letter-spacing: 0;
}

.header-left h1::after {
  content: "今日内容线索池";
  display: block;
  margin-top: 8px;
  color: var(--muted);
  font-size: 13px;
  font-weight: 600;
}

.date-text {
  color: var(--red);
  font-weight: 700;
}

.icon-btn {
  box-shadow: none;
  background: rgba(255, 255, 255, 0.9);
}

.controls-bar {
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
  box-shadow: var(--shadow);
}

.controls-bar select,
.btn,
.mode-toggle {
  border-radius: 8px;
}

.btn-primary {
  background: var(--red);
  box-shadow: 0 8px 18px rgba(180, 35, 24, 0.16);
}

.btn-primary:hover {
  background: #982018;
}

.btn-outline {
  border-color: rgba(17, 99, 79, 0.34);
  color: var(--primary);
}

.btn-outline:hover {
  background: var(--primary-soft);
}

.btn-amber {
  background: var(--amber);
}

.btn-green {
  background: var(--primary);
  box-shadow: 0 8px 18px rgba(17, 99, 79, 0.16);
}

.btn.is-thinking {
  background: linear-gradient(90deg, #0d4f40, var(--primary), var(--red), #0d4f40);
  background-size: 260% 100%;
  animation: aiButtonFlow 1.8s linear infinite;
}

.status-row {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #fff;
  box-shadow: none;
}

.news-list {
  gap: 10px;
}

.news-item {
  position: relative;
  border-radius: 8px;
  box-shadow: none;
  transition: border-color 150ms, box-shadow 150ms, transform 150ms;
}

.news-item:hover {
  border-color: rgba(17, 99, 79, 0.42);
  box-shadow: 0 8px 18px rgba(23, 32, 29, 0.08);
  transform: translateY(-1px);
}

.news-item.selected {
  border-color: var(--primary);
  background: linear-gradient(180deg, #f8fffb, var(--primary-soft));
}

.news-title {
  font-size: 15px;
  line-height: 1.55;
}

.news-meta {
  gap: 8px;
}

.news-category,
.badge-ai {
  border-radius: 6px;
}

.news-actions button {
  border-radius: 8px;
}

.empty-state,
.loading-row {
  border: 1px dashed rgba(17, 99, 79, 0.28);
  border-radius: 8px;
  background: #fff;
}

#generateBtn {
  border-radius: 8px;
}

.ai-process-panel {
  position: relative;
  max-width: 560px;
  margin: 12px auto 0;
  padding: 12px;
  overflow: hidden;
  border: 1px solid rgba(17, 99, 79, 0.22);
  border-radius: 8px;
  background:
    linear-gradient(90deg, rgba(17, 99, 79, 0.08), rgba(180, 35, 24, 0.05)),
    #fff;
  text-align: left;
  animation: aiPanelIn 180ms ease-out;
}

.ai-process-panel[hidden] {
  display: none;
}

.ai-process-head {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  color: var(--text);
  font-size: 13px;
}

.ai-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 22px;
  border-radius: 6px;
  background: var(--primary);
  color: #fff;
  font-size: 12px;
  font-weight: 800;
}

.ai-dots {
  display: inline-flex;
  gap: 3px;
  margin-left: auto;
}

.ai-dots i {
  width: 5px;
  height: 5px;
  border-radius: 999px;
  background: var(--red);
  animation: aiDot 1.1s ease-in-out infinite;
}

.ai-dots i:nth-child(2) {
  animation-delay: 140ms;
}

.ai-dots i:nth-child(3) {
  animation-delay: 280ms;
}

.ai-scanbar {
  position: relative;
  height: 7px;
  margin: 12px 0 10px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(17, 99, 79, 0.1);
}

.ai-scanbar span {
  position: absolute;
  inset: 0 auto 0 0;
  width: 42%;
  border-radius: inherit;
  background: linear-gradient(90deg, transparent, var(--primary), var(--red), transparent);
  animation: aiScan 1.45s ease-in-out infinite;
}

.ai-step-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 6px;
}

.ai-step-row span {
  min-width: 0;
  padding: 5px 4px;
  border: 1px solid rgba(17, 99, 79, 0.14);
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.75);
  color: var(--muted);
  font-size: 11px;
  font-weight: 700;
  text-align: center;
  animation: aiStepPulse 1.8s ease-in-out infinite;
}

.ai-step-row span:nth-child(2) {
  animation-delay: 220ms;
}

.ai-step-row span:nth-child(3) {
  animation-delay: 440ms;
}

.ai-step-row span:nth-child(4) {
  animation-delay: 660ms;
}

@keyframes aiButtonFlow {
  from { background-position: 0% 50%; }
  to { background-position: 260% 50%; }
}

@keyframes aiPanelIn {
  from { opacity: 0; transform: translateY(-4px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes aiDot {
  0%, 80%, 100% { opacity: 0.35; transform: translateY(0); }
  40% { opacity: 1; transform: translateY(-3px); }
}

@keyframes aiScan {
  0% { transform: translateX(-110%); }
  55%, 100% { transform: translateX(250%); }
}

@keyframes aiStepPulse {
  0%, 100% {
    border-color: rgba(17, 99, 79, 0.14);
    color: var(--muted);
  }
  45% {
    border-color: rgba(180, 35, 24, 0.34);
    color: var(--primary);
  }
}

.article-card {
  border-radius: 8px;
  box-shadow: var(--shadow);
}

.article-card-header {
  background: linear-gradient(90deg, var(--primary-soft), var(--red-soft));
}

.article-card-header h2,
.article-card-body h3 {
  color: var(--primary);
}

.article-card-body {
  font-size: 15px;
  line-height: 1.85;
}

.source-link a {
  color: var(--primary);
  font-weight: 700;
}

.settings-dialog {
  border-radius: 8px;
}

@media (max-width: 600px) {
  .header {
    min-height: auto;
    padding: 14px 12px 16px 18px;
  }

  .header-left h1 {
    font-size: 22px;
  }

  .header-left h1::after {
    font-size: 12px;
  }
}
</style>
</head>
<body>

<main class="app-shell">
  <!-- Header -->
  <header class="header">
    <div class="header-left">
      <h1>强安视界</h1>
      <div class="date-text" id="todayDate"></div>
    </div>
    <div class="header-actions">
      <button class="icon-btn" id="settingsBtn" title="设置">&#9881;</button>
    </div>
  </header>

  <!-- Controls -->
  <div class="controls-bar">
    <select id="categoryFilter">
