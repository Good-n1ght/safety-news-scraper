window.DS_BASE_URL    = localStorage.getItem("ds_base_url")    || DEFAULT_BASE_URL;
window.PEXELS_API_KEY = localStorage.getItem("pexels_api_key") || "";

/* ---------- 工具函数 ---------- */
function showToast(msg) {
  var toast = document.getElementById("toast");
  if (!toast) return;
  toast.textContent = msg;
  toast.classList.add("show");
  clearTimeout(showToast._timer);
  showToast._timer = setTimeout(function() {
    toast.classList.remove("show");
  }, 1800);
}

function escapeHtml(s) {
  return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
}

function getApiBase() {
  return (window.DS_BASE_URL || DEFAULT_BASE_URL).replace(/\/+$/, "");
}

function getApiKey() {
  return window.DS_API_KEY || DEFAULT_API_KEY;
}

/* ---------- AI API 通用调用 ---------- */
function callDeepSeekDraft(params) {
  var baseUrl = getApiBase();
  var systemPrompt = params.systemPrompt;
  var userPrompt = params.userPrompt;
  var model = window.DS_MODEL || DEFAULT_MODEL;
  var maxTokens = params.maxTokens || gd("max_tokens", 3600);
  var temperature = (params.temperature !== undefined) ? params.temperature : gd("temperature", 0.7);
  var useJsonFormat = (params.jsonFormat !== false);

  var body = {
    model: model,
    messages: [
      { role: "system", content: systemPrompt },
      { role: "user", content: userPrompt }
    ],
    temperature: temperature,
    max_tokens: maxTokens,
    stream: false
  };
  if (useJsonFormat) {
    body.response_format = { type: "json_object" };
  }

  return fetch(baseUrl + "/v1/chat/completions", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + getApiKey()
    },
    body: JSON.stringify(body)
  }).then(function(response) {
    return response.json().then(function(payload) {
      if (!response.ok) {
        var msg = (payload && payload.error && payload.error.message) ? payload.error.message : ("HTTP " + response.status);
        throw new Error(msg);
      }
      var content = payload && payload.choices && payload.choices[0] && payload.choices[0].message && payload.choices[0].message.content;
      if (!content) {
        throw new Error("API 返回内容为空");
      }
      return content.trim();
    });
  });
}

/* ---------- Pexels 配图 ---------- */
function fetchPexelsImages(keywords) {
  if (!keywords || !keywords.length) return Promise.resolve([]);
  var apiKey = window.PEXELS_API_KEY;
  if (!apiKey) return Promise.resolve([]);

  return Promise.all(keywords.map(function(kw) {
    return fetch("https://api.pexels.com/v1/search?query=" + encodeURIComponent(kw) + "&per_page=1", {
      headers: { "Authorization": apiKey }
    }).then(function(resp) {
      if (!resp.ok) return null;
      return resp.json();
    }).then(function(data) {
      if (data && data.photos && data.photos.length) {
        return {
          keyword: kw,
          url: data.photos[0].src.medium,
          photographer: data.photos[0].photographer
        };
      }
      return null;
    }).catch(function() { return null; });
  })).then(function(results) {
    return results.filter(Boolean);
  });
}

function injectPexelsImages(html, pexelsResults) {
  if (!html || !pexelsResults || !pexelsResults.length) return html;
  var result = html;
  pexelsResults.forEach(function(img) {
    var imgTag = '<img src="' + img.url + '" alt="' + escapeHtml(img.keyword || '配图') + '" style="max-width:100%;border-radius:8px;margin:12px 0;" loading="lazy" />' +
      '<p style="font-size:11px;color:#999;text-align:center;">Photo by ' + escapeHtml(img.photographer || 'Pexels') + ' on Pexels</p>';
    var hintMarker = "<div class='img-hint'>";
    var idx = result.indexOf(hintMarker);
    if (idx !== -1) {
      var endIdx = result.indexOf("</div>", idx);
      if (endIdx !== -1) {
        result = result.substring(0, idx) + imgTag + result.substring(endIdx + 6);
      }
    }
  });
  return result;
}

/* ---------- 设置面板 ---------- */
function initSettings() {
  var els = {
    settingsOverlay: document.getElementById("settingsOverlay"),
    settingsBtn: document.getElementById("settingsBtn"),
    settingsCancel: document.getElementById("settingsCancel"),
    settingsSave: document.getElementById("settingsSave"),
    brandSelect: document.getElementById("brandSelect"),
    modelSelect: document.getElementById("modelSelect"),
    apiKeyInput: document.getElementById("apiKeyInput"),
    baseUrlInput: document.getElementById("baseUrlInput"),
    pexelsKeyInput: document.getElementById("pexelsKeyInput")
  };

  if (!els.settingsBtn || !els.settingsOverlay) return;

  // 读取当前设置
  if (els.apiKeyInput) els.apiKeyInput.value = window.DS_API_KEY || "";
  if (els.baseUrlInput) els.baseUrlInput.value = window.DS_BASE_URL || DEFAULT_BASE_URL;
  if (els.pexelsKeyInput) els.pexelsKeyInput.value = window.PEXELS_API_KEY || "";

  // ---- 两级模型选择器 ----
  var savedModel = window.DS_MODEL || DEFAULT_MODEL;
  var savedBrand = getBrandForModel(savedModel);

  // 填充品牌下拉
  if (els.brandSelect) {
    els.brandSelect.innerHTML = "";
    MODEL_BRANDS.forEach(function(brand) {
      var opt = document.createElement("option");
      opt.value = brand.name;
      opt.textContent = brand.name;
      els.brandSelect.appendChild(opt);
    });
    els.brandSelect.value = savedBrand.name;
  }

  // 品牌切换 → 刷新模型列表
  function populateModels(brandName) {
    if (!els.modelSelect) return;
    els.modelSelect.innerHTML = "";
    var brand = null;
    for (var i = 0; i < MODEL_BRANDS.length; i++) {
      if (MODEL_BRANDS[i].name === brandName) { brand = MODEL_BRANDS[i]; break; }
    }
    if (!brand) return;
    brand.models.forEach(function(modelId) {
      var info = MODEL_MAP[modelId];
      if (!info) return;
      var opt = document.createElement("option");
      opt.value = modelId;
      opt.textContent = info.name;
      els.modelSelect.appendChild(opt);
    });
    // 如果当前保存的模型属于该品牌，选中它；否则选第一个
    if (savedModel && brand.models.indexOf(savedModel) !== -1) {
      els.modelSelect.value = savedModel;
    } else {
      els.modelSelect.value = brand.models[0];
    }
    // 更新 Base URL
    updateBaseUrl();
  }

  function updateBaseUrl() {
    if (!els.modelSelect || !els.baseUrlInput) return;
    var modelId = els.modelSelect.value;
    var info = MODEL_MAP[modelId];
    if (info && info.baseUrl) els.baseUrlInput.value = info.baseUrl;
  }

  if (els.brandSelect) {
    els.brandSelect.addEventListener("change", function() {
      savedModel = null; // 切换品牌后不再记住旧模型
      populateModels(els.brandSelect.value);
    });
    // 初始填充
    populateModels(savedBrand.name);
  }

  if (els.modelSelect && els.baseUrlInput) {
    els.modelSelect.addEventListener("change", updateBaseUrl);
  }

  // 打开设置面板
  els.settingsBtn.addEventListener("click", function() {
    // 打开时重新同步品牌
    var curModel = window.DS_MODEL || DEFAULT_MODEL;
    var curBrand = getBrandForModel(curModel);
    if (els.brandSelect) els.brandSelect.value = curBrand.name;
    savedModel = curModel;
    populateModels(curBrand.name);
    els.settingsOverlay.hidden = false;
  });

  // 关闭
  els.settingsCancel.addEventListener("click", function() {
    els.settingsOverlay.hidden = true;
  });

  // 保存
  els.settingsSave.addEventListener("click", function() {
    var newKey = els.apiKeyInput ? els.apiKeyInput.value.trim() : "";
    var newModel = els.modelSelect ? els.modelSelect.value : DEFAULT_MODEL;
    var newBaseUrl = els.baseUrlInput ? els.baseUrlInput.value.trim() : "";
    var newPexelsKey = els.pexelsKeyInput ? els.pexelsKeyInput.value.trim() : "";

    if (newKey) {
      localStorage.setItem("ds_api_key", newKey);
      window.DS_API_KEY = newKey;
    } else {
      localStorage.removeItem("ds_api_key");
      window.DS_API_KEY = DEFAULT_API_KEY;
    }

    localStorage.setItem("ds_model", newModel);
    window.DS_MODEL = newModel;

    if (newBaseUrl) {
      localStorage.setItem("ds_base_url", newBaseUrl);
      window.DS_BASE_URL = newBaseUrl;
    } else {
      localStorage.removeItem("ds_base_url");
      window.DS_BASE_URL = DEFAULT_BASE_URL;
    }

    if (newPexelsKey) {
      localStorage.setItem("pexels_api_key", newPexelsKey);
      window.PEXELS_API_KEY = newPexelsKey;
    } else {
      localStorage.removeItem("pexels_api_key");
      window.PEXELS_API_KEY = "";
    }

    els.settingsOverlay.hidden = true;
    showToast("API 设置已保存");
  });
}

